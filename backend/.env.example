# ========== LLM 提供商切换 ==========
# openai | anthropic 二选一。两路均接入 DeepSeek（OpenAI 标准走 OpenAI 兼容端点，
# Anthropic 标准走 anthropic 兼容端点）。切换只改这一行，业务代码不变。
LLM_PROVIDER=anthropic

# ========== OpenAI 标准接口 ==========
# 端点 {OPENAI_BASE_URL}/chat/completions
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-***
OPENAI_MODEL=deepseek-v4-pro

# ========== Anthropic 标准接口 ==========
# 端点 {ANTHROPIC_BASE_URL}/v1/messages
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_API_KEY=sk-***
ANTHROPIC_MODEL=deepseek-v4-pro

# ========== 应用配置 ==========
DATABASE_URL=sqlite:///./vibechat.db
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,https://vibechat.wukangkang.com
HOST=127.0.0.1
PORT=8000
LLM_MAX_TOKENS=4096
